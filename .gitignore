# .gitignore for the Awesome-Reward-Hacking repo

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# Build / caches
node_modules/
.cache/

# Local-only drafts
drafts/
*.draft.md

# Large PDFs we don't track (we link to arXiv instead)
# The survey PDF lives on arXiv: https://arxiv.org/abs/2604.13602
2604.13602v1.pdf
*.pdf

.claude/